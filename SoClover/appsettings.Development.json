{
  "Llm": {
    "provider": "OpenAI",
    "baseUrl": "http://localhost:1234/v1",
    "defaultModel": "google/gemma-4-12b-qat",
    "maxConcurrency": 1,
    "timeoutSeconds": 500,
    "defaultTemperature": 1.0,
    "topP": 0.95,
    "maxOutputTokens": 6000,
    "maxRetries": 1,
    "reasoningEnabled": false,
    "reasoningSystemPromptPathEnabler": "Infrastructure/AI/Prompts/ministral-reasoning-system.md",
    "generationMode": "PerDirection"
  },
  "AIPlayers": {
    "enabled": true
  }
}
