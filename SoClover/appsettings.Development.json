{
  "Llm": {
    "provider": "OpenAI",
    "baseUrl": "http://localhost:1234/v1",
    "defaultModel": "mistralai/ministral-3-14b-reasoning",
    "maxConcurrency": 1,
    "timeoutSeconds": 300,
    "defaultTemperature": 1.0,
    "topP": 0.95,
    "maxOutputTokens": 6000,
    "maxRetries": 0,
    "reasoningEnabled": true,
    "reasoningSystemPromptPath": "Infrastructure/AI/Prompts/ministral-reasoning-system.md"
  },
  "AIPlayers": {
    "enabled": true
  }
}
