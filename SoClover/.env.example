# Copier ce fichier en .env et renseigner les vraies valeurs avant le déploiement.
# .env est ignoré par git — ne jamais committer les vraies valeurs.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=soclover

# Frontend debug mode (VITE_ prefix = exposé au client par Vite)
VITE_DEBUG_MODE=false

# ---------------------------------------------------------------------------
# LLM configuration
#
# Dev local (LM Studio)
# ---------------------
# Le défaut dev (LM Studio OpenAI-compatible) vit dans
# `appsettings.Development.json` (`Llm.provider`, `Llm.baseUrl`, `Llm.apiKey`,
# `Llm.defaultModel`, `Llm.maxConcurrency`). Lancer LM Studio, charger un
# modèle FR (ex. `lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF`,
# `mistralai/Mistral-7B-Instruct-v0.3-GGUF` ou
# `Qwen/Qwen2.5-7B-Instruct-GGUF`), activer le serveur HTTP. Aucune
# modification de `.env` n'est nécessaire en dev.
#
# Pour overrider sans modifier `appsettings.Development.json` (ex. tester un
# autre modèle ponctuellement), utiliser les env vars `LLM__*` ci-dessous :
#
#   LLM__DEFAULTMODEL=Qwen/Qwen2.5-7B-Instruct-GGUF
#   LLM__MAXCONCURRENCY=2
#
# Pour tester Anthropic en local sans toucher au repo :
#   dotnet user-secrets set "Llm:Provider"     "Anthropic" --project SoClover
#   dotnet user-secrets set "Llm:DefaultModel" "claude-haiku-4-5" --project SoClover
#   dotnet user-secrets set "Llm:ApiKey"       "sk-ant-..." --project SoClover
#
# Production (Anthropic)
# ----------------------
# `appsettings.Production.json` fournit provider/baseUrl/defaultModel/
# maxConcurrency. Le seul secret à injecter via `.env` est la clé API.
# NE PAS dupliquer les autres valeurs ici.
# ---------------------------------------------------------------------------
LLM__APIKEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx