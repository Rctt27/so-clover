# Copier ce fichier en .env et renseigner les vraies valeurs avant le déploiement.
# .env est ignoré par git — ne jamais committer les vraies valeurs.
#
# Règle générale (cf. CLAUDE.md, section Configuration) :
#   - Secrets et valeurs machine-specific → ce fichier (.env)
#   - Valeurs non-secrètes versionnables → appsettings*.json

# === Secrets PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=soclover

# === Frontend (VITE_ = exposé au client) ===
VITE_DEBUG_MODE=false

# === Secret LLM ===
# Dev local (LM Studio) : la clé n'est pas vérifiée mais doit être non-vide
# (LlmOptionsValidator).
#   LLM__APIKEY=lm-studio
#
# Production (Anthropic) : clé réelle.
LLM__APIKEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Échappatoires (à éviter en temps normal) ===
# La connexion LLM (Provider, BaseUrl, DefaultModel, MaxConcurrency) vit dans
# appsettings.{Env}.json — c'est la source de vérité versionnée. Les vars
# LLM__* ci-dessous peuvent overrider PONCTUELLEMENT sans toucher au repo
# (ex. tester un autre modèle local) :
#
#   LLM__DEFAULTMODEL=Qwen/Qwen2.5-7B-Instruct-GGUF
#   LLM__MAXCONCURRENCY=2
#
# Pour tester Anthropic en local sans modifier le repo, préférer user-secrets :
#   dotnet user-secrets set "Llm:Provider"     "Anthropic" --project SoClover
#   dotnet user-secrets set "Llm:DefaultModel" "claude-haiku-4-5" --project SoClover
#   dotnet user-secrets set "Llm:ApiKey"       "sk-ant-..." --project SoClover
