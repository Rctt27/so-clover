# Copier ce fichier en .env et renseigner les vraies valeurs avant le déploiement
# .env est ignoré par git — ne jamais committer les vraies valeurs

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=soclover

# Frontend debug mode: set to true to enable verbose logs and Zustand DevTools integration
# (VITE_ prefix = exposé au client par Vite uniquement)
VITE_DEBUG_MODE=false

# ---------------------------------------------------------------------------
# LLM provider (Epic 04). Convention .NET : double underscore = sous-section.
# Dev local (LM Studio) : valeurs par défaut dans appsettings.json suffisent,
# rien à définir ici.
#
# Production (Anthropic) : décommenter et renseigner les 3 lignes ci-dessous.
# ---------------------------------------------------------------------------
LLM__PROVIDER=Anthropic
LLM__APIKEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM__DEFAULTMODEL=claude-haiku-4-6
#
# Optionnels (les défauts d'appsettings.Production.json sont OK):
LLM__BASEURL=https://api.anthropic.com
LLM__MAXCONCURRENCY=4
LLM__MAXCALLSPERGAME=200
LLM__TIMEOUTSECONDS=30