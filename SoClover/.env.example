# Copier ce fichier en .env et renseigner les vraies valeurs avant le déploiement.
# .env est ignoré par git — ne jamais committer les vraies valeurs.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=soclover

# Frontend debug mode (VITE_ prefix = exposé au client par Vite)
VITE_DEBUG_MODE=false

# ---------------------------------------------------------------------------
# LLM secrets (production uniquement)
#
# En dev local, NE PAS toucher ce fichier. La config LM Studio vit dans
# appsettings.Development.json (provider, baseUrl, model, maxConcurrency=1).
# Pour tester Anthropic en local sans modifier le repo :
#   dotnet user-secrets set "Llm:ApiKey" "sk-ant-..." --project SoClover
#
# En production, le seul secret est la clé API. Tous les autres défauts
# (provider, baseUrl, model, maxConcurrency=4) viennent de
# appsettings.Production.json et ne doivent PAS être dupliqués ici.
# ---------------------------------------------------------------------------
LLM__APIKEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx