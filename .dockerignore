**/.dockerignore
**/.env
**/.git
**/.gitignore
**/.project
**/.settings
**/.toolstarget
**/.vs
**/.vscode
**/.idea
**/*.*proj.user
**/*.dbmdl
**/*.jfm
**/azds.yaml
**/bin
**/charts
**/docker-compose*
**/Dockerfile*
**/node_modules
**/npm-debug.log
**/obj
**/secrets.dev.yaml
**/values.dev.yaml
LICENSE
README.md
cat > .dockerignore <<'EOF'
# Ignore build outputs so Windows obj/bin do not get copied into Linux image
**/bin
**/obj

# Common noise
.git
.vs
*.user
*.suo
*.tgz
EOF